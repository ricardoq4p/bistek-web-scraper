{
  "name": "bistek-web-scraper",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "postCreateCommand": "bash scripts/setup_codespaces.sh",
  "forwardPorts": [5000, 8080, 3306],
  "portsAttributes": {
    "5000": {
      "label": "Front-end Bistek",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Adminer",
      "onAutoForward": "notify"
    },
    "3306": {
      "label": "MySQL",
      "onAutoForward": "silent"
    }
  }
}
